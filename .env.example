# Copia este archivo a .env y ajusta los valores.
# En producción (Render) estas variables se definen en el panel de entorno.

# Clave secreta de Django. Genera una nueva para producción.
SECRET_KEY=django-insecure-clave-solo-para-desarrollo-cambiar-en-produccion

# True en desarrollo, False en producción.
DEBUG=True

# Hosts permitidos, separados por comas.
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com,.railway.app,.up.railway.app

# Orígenes de confianza para CSRF (requerido en producción con HTTPS).
CSRF_TRUSTED_ORIGINS=https://*.railway.app,https://*.up.railway.app

# URL de la base de datos (opcional). Si se define, sobrescribe SQLite.
# Ejemplo Postgres: postgres://usuario:clave@host:5432/nombre_bd
DATABASE_URL=

